public class MaxPQ {
    private Patient[] arr;
    private int max;
    private int size;
    private int count;

    public MaxPQ() {
        this.arr = new Patient[10];
        this.max = 10;
        this.size = 0;
        this.count = 0;
    }

    public void insert(Patient p) {
        arr[size] = p;
        if (size != 0) swim(size, (int) Math.floor(size / 2));
        size ++;
        resize();
    }

