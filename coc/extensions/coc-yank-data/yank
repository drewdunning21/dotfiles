	        if (parent.key.compareTo(key) > 0) {
	            return (parent.left != null) ? parent.left.val : null;
	        } else if (parent.key.compareTo(key) == 0) {
	            return (parent != null) ? parent.val : null;
	        }
	        return (parent.right != null) ? parent.right.val : null;
	    }
	
	
