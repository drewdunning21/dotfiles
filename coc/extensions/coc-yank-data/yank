	public class FiveQuick {
	
	    // main sort method that calls the helper quicksort
	    public static void sort(int[] a) {
	        quicksort(a, 0, a.length);
	    }
	
	    // recursive method that does the quicksorting
	    // calls the setPivots function to gets the pivots and
	    // makes the recursive call on the 3 partitions
	    private static void quicksort(int[] a, int start, int end) {
	        if (end - start <= 1) {
	            return;
	        }
	        int[] pivots = setPivots(a,start,end);
	        // recursive calls for the 3 partitions
	        quicksort(a,start,pivots[0]);
	        quicksort(a,pivots[0],pivots[1]);
	        quicksort(a,pivots[1],end);
	    }
	
	    // sets the pivots for the first element in the array and the last.
	    // has two loops, the first on where it looks for elements smaller than
	    // pivot one and the second where it looks for elements larger than pivot 2
	    private static int[] setPivots(int[] a, int start, int end) {
	        if (a[start] > a[end-1]) {swap(a,0,end-1);}
	        int x1 = a[start];
	        int p1 = start;
	        int f1 = p1+1;
	        int i = f1;
	        while (i < end) {
	            if (a[i] < x1) {
	                swap(a,i,f1);
	                swap(a,f1,p1);
	                p1++;
	                f1++;
	            }
	            else if (a[i] == x1) {
	                swap(a,f1,i);
	                f1++;
	            }
	            i++;
	        }
	        int x2 = a[end-1];
	        int p2 = end-1;
	        int f2 = p2-1;
	        i = f2;
	        while (i > p1) {
	            if (a[i] > x2) {
	                swap(a,i,f2);
	                swap(a,f2,p2);
	                f2--;
	                p2--;
	            }
	            else if (a[i] == x2) {
	                swap(a,f2,i);
	                f2--;
	            }
	            i--;
	        }
	        return new int[]{p1,p2};
	    }
	
	    // swaps 2 elements of the array and 2 different indexes
	    private static void swap(int[] a, int ind1, int ind2) {
	        int temp = a[ind1];
	        a[ind1] = a[ind2];
	        a[ind2] = temp;
	    }
	}
