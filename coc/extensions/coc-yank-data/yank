	    for i in range(len(m)):
	        for j in range(i, len(m[i])):
	            m[i][j],m[j][i] = m[j][i],m[i][j]
	    # reverse lists
	    for i in range(len(m)):
	        m[i] = m[i][::-1]
	    return m
