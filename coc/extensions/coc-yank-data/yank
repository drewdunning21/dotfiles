	public class MaxPQ {
	    private Patient[] arr;
	    private int max;
	    private int size;
	    private int count;
	
	    // constructor for the max pq class
	    public MaxPQ() {
	        this.arr = new Patient[10];
	        this.max = 10;
	        this.size = 0;
	        this.count = 0;
	    }
	
	    // inserts patient into the queue
	    public void insert(Patient p) {
	        arr[size] = p;
	        // if the size isn't zero then it needs to swim to be put
	        // in the right spot
	        if (size != 0) swim(size, getParent(size));
	        size ++;
	        // calls resize every time where it will decide if
	        // a resize needs to be made
	        resize();
	    }
	
	    // a helper function to find the parent elements of a child node
	    private int getParent(int i){
	        return  (i % 2 == 0) ? ((int)Math.floor(i/2)-1) : ((int)Math.floor(i/2));
	    }
	
	    // returns and gets rid of the max element in the pq
	    public Patient delMax() throws EmptyQueueException {
	        if (isEmpty()) throw new EmptyQueueException();
	        Patient max = arr[0];
	        arr[0] = arr[size-1];
	        size --;
	        // calls sink to reorganize the pq
	        sink(0, getMaxChild(0));
	        return max;
	    }
	
	    // returns the max element in the pq wihtout removing it
	    public Patient getMax() throws EmptyQueueException {
	        if (isEmpty()) throw new EmptyQueueException();
	        return arr[0];
	    }
	
	    // returns the number of elements in the pq
	    public int size() {
	        return size;
	    }
	
	    // returns true if the pq has zero patients in it
	    public boolean isEmpty() {
	        return (size == 0);
	    }
	
	    // recurive function to swap the child node with it's parent
	    // while it is greater than the parent node
	    private void swim(int cur, int parent) {
	        // if statement to check if it is greater than parent
	        if(cur > 0 && arr[cur].compareTo(arr[parent]) > 0) {
	            swap(cur, parent);
	            swim(parent, getParent(parent));
	        }
	    }
	
	    // recurusive function to swap parent with child node while the
	    // child node is greater
	    private void sink(int cur, int maxChild) {
	        // checks of the child node is greater than the parent and swaps if so
	        if (maxChild != cur && arr[cur].compareTo(arr[maxChild]) < 0) {
	            swap(cur, maxChild);
	            sink(maxChild, getMaxChild(maxChild));
	        }
	    }
	
	    // returns the max child value of a parent at index i
	    private int getMaxChild(int i) {
	        int kid = (2 * i + 1);
	        // checks if the first child is in the array
	        boolean firstIn = kid < size;
	        // checks if the second child is in the array
	        boolean secondIn = kid + 1 < size;
	        if (firstIn && !secondIn) return kid;
	        else if (firstIn && secondIn) {
	            // if boths kids are in the array it returns the greater of the two
	            return (arr[kid].compareTo(arr[kid+1]) > 0) ? kid : kid+1;
	        }
	        return i;
	    }
	
	    // swaps elements at index i and j
	    private void swap(int i, int j) {
	        Patient temp = arr[i];
	        arr[i] = arr[j];
	        arr[j] = temp;
	    }
	
	    // resizes the array if it is at its max size
	    private void resize() {
	        // doubles the max size of array if it is full
	        if (size == max) max *= 2;
	        // returns if a resize is not necessary
	        else return;
	        // creates new array with the new doubled size
	        Patient[] newArr = new Patient[max];
	        for (int i = 0; i < size; i ++) {
	            newArr[i] = arr[i];
	        }
	        count = count + (size * 2);
	        arr = newArr;
	    }
	}
