	    // retrieves a patient from the hash table. the name
	    // is hashed and located in the table
	    public Patient get(String name) {
	        int hash = getHash(name);
	        if (table[hash] == null) {return null;}
	        ArrayList<Patient> arr = table[hash];
	        for (int i = 0; i < arr.size(); i++) {
	            if (arr.get(i).name() == name) {
	                return arr.get(i);
	            }
	        }
	        return null;
	    }
	
	    // puts a new element in the hashmap. hashes the name and
	    // adds it to the chain of that location
	    public void put(Patient p) {
	        if (get(p.name()) != null) {return;}
	        int hash = getHash(p.name());
	        if (table[hash] == null) {table[hash] = new ArrayList<Patient>();}
	        table[hash].add(p);
	        size += 1;
	        if (size == table.length * 2) {rehash();}
	    }
	
	    // rehashes the whole array when it gets to large. it sets the
	    // size of the new array to the next prime number
	    private void rehash() {
	        ArrayList<Patient>[] clone = table.clone();
	        table = new ArrayList[getNextPrime(table.length*2)];
	        for(ArrayList<Patient> chain : clone) {
	            if (chain != null) {
	                for(Patient p : chain) {
	                    this.insidePut(p);
	                }
	            }
	        }
	    }
	
	    // private method used by rehash to put elements in the array
	    // without incirmenting the size
	    private void insidePut(Patient p) {
	        int hash = getHash(p.name());
	        if (table[hash] == null) {table[hash] = new ArrayList<Patient>();}
	        table[hash].add(p);
	        if (size == table.length * 2) {rehash();}
	    }
	
	    // takes an item out of the table. it locates it by hashing the name
	    // and removes it from the array list
	    public Patient remove(String name) {
	        int hash = getHash(name);
	        if (table[hash] == null) {return null;}
	        ArrayList<Patient> arr = table[hash];
	        for (int i = 0; i < arr.size(); i++) {
	            if (arr.get(i).name() == name) {
	                // might need to remove from pq idk
	                size --;
	                return arr.remove(i);
	            }
	        }
	        return null;
	    }
	
	    // returns the size of array
	    public int size() {return size;}
	
	    // returns the table array
	    public ArrayList<Patient>[] getArray() {return table;}
	
	    // gets the hash value of a string
	    private int getHash(String n) {
	        int hash = n.hashCode() % table.length;
	        if (hash < 0) {hash += table.length;}
	        return hash;
	    }
	
	    //get the next prime number p >= num
	    public int getNextPrime(int num) {
	        if(num == 2 || num == 3)
	            return num;
	        int rem = num % 6;
	        switch(rem) {
	            case 0: num++; break;
	            case 2: num+=3; break;
	            case 3: num+=2; break;
	            case 4: num++; break;
	        }
	        while(!isPrime(num)) {
	            if(num % 6 == 5)
	                num+=2;
	            else
	                num+=4;
	        }
	        return num;
	    }
	
	    //determines if a number > 3 is prime
	    public boolean isPrime(int num) {
	        int x = 3;
	        for(int i = x; i <= (int)Math.sqrt(num); i+=2)
	            if(num % i == 0)
	                return false;
	        return true;
	    }
	}
