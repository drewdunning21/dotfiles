	class Solution:
	    def sortColors(self, nums):
	        """
	        Do not return anything, modify nums in-place instead.
	        """
	        seen = 0
	        i = 0
	        while seen < len(nums):
	            if nums[i] == 0 and seen != 0:
	                tmp = nums.pop(i)
	                nums.insert(0,tmp)
	                i += 1
	            elif nums[i] ==2:
	                tmp = nums.pop(i)
	                nums.insert(len(nums),tmp)
	            else:
	                i += 1
	            seen += 1
