	class Solution:
	    def sortedArrayToBST(self, nums):
	        root = TreeNode(nums[0],None,None)
	        for i in range(1,len(nums)//2):
	            newNode = TreeNode(nums[i], root,None)
	            root.left(newNode)
	            root = newNode
	        leaf = root
	        for i in range(len(nums)//2 + 1, len(nums):
	            newNode = TreeNode(nums[i], None,nums[i])
	            leaf.right = newNode
	            leaf = newNode
	        return root
