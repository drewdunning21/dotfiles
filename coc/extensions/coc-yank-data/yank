	        Node parent = findParent(key, this.root);
	        if (parent.key.compareTo(key) == 0) {
	            return parent;
	        } else if (parent.key.compareTo(key) > 0) {
	            return (parent.left != null) ? parent.left : null;
	        }
	        return (parent.right != null) ? parent.right : null;
	    }
	
