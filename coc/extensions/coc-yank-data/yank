	    private Node findParent(Key key, Node node) {
	        // check if right child is the key were searching for
	        if (node.key.compareTo(key) < 0) {
	            if (node.right == null) {
	                return node;
	            }
	            // check if right child is the key were searching for
	            else if (node.right.key.compareTo(key) == 0) {
	                return node;
	            }
	            return this.findParent(key, node.right);
	        }
	        if (node.left == null) {
	            return node;
	        }
	        // look if left child is the key were searching for
	        else if (node.left.key.compareTo(key) == 0) {
	            return node;
	        }
	        return this.findParent(key, node.left);
	    }
