	\begin{document}
	
	\begin{itemize}
	    \item[1.]
	        \begin{itemize}
	            \item[a.]
	                For all integers $m$, $n$, and $p$, $m+n+p$ is even if and only if either 1 or 3 of the numbers must be even\\\\
	                Proving: For all integers $m$, $n$, and $p$ if 1 or 3 of the numbers are even, $m+n+p$ is even\\
	                \underline{Proof by cases:}\\
	                Definition of an even number: $\exists _{k \in \mathbb{Z}} \text{ s.t. } n=2k$ \\
	                Definition of an odd number: $\exists _{k \in \mathbb{Z}} \text{ s.t. } n=2k+1$ \\
	                \underline{Case 1: 1 of $m$, $n$, or $p$ is even}\\
	                Assume that $m$ is even and $n$ and $p$ are odd\\
	                $m = 2k$, $n = 2k+1$, $p = 2k+1$ \\
	                $m+n+p = 2k+2k+1+2k+1 = 6k+2 = 2(3k+1)$\\
	                $l = 3k+1$\\
	                $m+n+p = 2(l)$\\
	                $2(l)$ is the definition of an even number, therefore if 1 number of $m$, $n$ and $p$ is even, $m+n+p$ is even\\
	                % \underline{Case 2: 2 of $m$, $n$, or $p$ is even}\\
	                % Assume that $m$ and $n$ are even and $p$ is odd\\
	                % $m = 2k$, $n = 2k$, $p = 2k+1$ \\
	                % $m+n+p= 2k+2k+2k+1 = 6k+1 = 2(3k) + 1$\\
	                % $l = 3k$\\
	                % $m+n+p = 2l + 1$ \\
	                % $2(l)$ is the definition of an even number, and any even plus 1 is odd. Therefore if 2 numbers of $m$, $n$ and $p$ are even, $m+n+p$ is odd\\
	                \underline{Case 2: All 3 of $m$, $n$, or $p$ are even}\\
	                Assume that $m$, $n$, and $p$ are even\\
	                $m = 2k$, $n = 2k+1$, $p = 2k+1$ \\
	                $m+n+p = 2k+2k+2k = 6k = 2(3k)$\\
	                $l = 3k$\\
	                $m+n+p = 2(l)$\\
	                $2(l)$ is the definition of an even number, therefore if all 3 of $m$, $n$ and $p$ are even, $m+n+p$ is even\\\\
	                Proving: For all integers $m$, $n$, and $p$ if $m+n+p$ is even, then either 1 or 3 of the numbers must be even\\
	                \underline{Proof by contrapositive:}\\
	                Contrapositive: For all integers $m$, $n$, and $p$, if 2 of the numbers are even then $m+n+p$ is odd \\
	                Definition of an even number: $\exists _{k \in \mathbb{Z}} \text{ s.t. } n=2k$ \\
