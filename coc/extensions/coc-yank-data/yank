	import java.util.Arrays;
	
	public class MaxPQ {
	    private Patient[] arr;
	    private int max;
	    private int next;
	    private int count;
	    private PHashtable table;
	
	    // constructor for the max pq class
	    public MaxPQ() {
	        this.arr = new Patient[10];
	        this.next = 0;
	        this.max = 10;
	        this.count = 0;
	        this.table = new PHashtable();
	    }
	
	    // inserts patient into the queue
	    public void insert(Patient p) {
	        arr[next] = p;
	        table.put(p);
	        // if the size isn't zero then it needs to swim to be put
	        // in the right spot
	        int i;
	        if (next != 0) {i = swim(next, getParent(next));}
	        else i = 0;
	        next ++;
	        p.setPosInQueue(i);
	        // calls resize every time where it will decide if
	        // a resize needs to be made
	        resize();
	    }
	
	    // removes an element from the queue and reorganizes it
	    // after
	    public Patient remove(String s) {
	        Patient toRem = table.get(s);
	        int index = toRem.posInQueue();
	        arr[index] = null;
	        toRem.setPosInQueue(-1);
	        reQueue();
	        return toRem;
	    }
	
	    // reorganizes the array after something is removed fomr it
	    private void reQueue() {
	        Patient[] clone = arr.clone();
	        arr = new Patient[max];
	        next = 0;
	        for (int j = 0; j < clone.length; j ++) {
	            if (clone[j] == null) continue;
	            Patient p = clone[j];
	            arr[next] = p;
	            // if the size isn't zero then it needs to swim to be put
	            // in the right spot
	            int i;
	            if (next != 0) {i = swim(next, getParent(next));}
	            else i = 0;
	            next ++;
	            p.setPosInQueue(i);
	            // calls resize every time where it will decide if
	            // a resize needs to be made
	            resize();
	        }
	    }
	
	    // a helper function to find the parent elements of a child node
	    private int getParent(int i){
	        return  (i % 2 == 0) ? ((int)Math.floor(i/2)-1) : ((int)Math.floor(i/2));
	    }
	
	    // returns and gets rid of the max element in the pq
	    public Patient delMax() throws EmptyQueueException {
	        if (isEmpty()) throw new EmptyQueueException();
	        Patient max = arr[0];
	        max.setPosInQueue(-1);
	        arr[0] = arr[next-1];
	        arr[next-1] = null;
	        next --;
	        // calls sink to reorganize the pq
	        sink(0, getMaxChild(0));
	        return max;
	    }
	
	    // recurusive function to swap parent with child node while the
	    // child node is greater
	    private void sink(int cur, int maxChild) {
	        // checks if the child node is greater than the parent and swaps if so
	        if (arr[maxChild] != null && maxChild != cur && arr[cur].compareTo(arr[maxChild]) < 0) {
	            swap(cur, maxChild);
	            sink(maxChild, getMaxChild(maxChild));
	        }
	    }
	
	    // returns the max element in the pq wihtout removing it
	    public Patient getMax() throws EmptyQueueException {
	        if (isEmpty()) throw new EmptyQueueException();
	        return arr[0];
	    }
	
	    // returns the number of elements in the pq
	    public int size() {
	        return next;
	    }
	
	    // returns true if the pq has zero patients in it
	    public boolean isEmpty() {
	        return (arr[0] == null);
	    }
	
	    // recurive function to swap the child node with it's parent
	    // while it is greater than the parent node
	    private int swim(int cur, int parent) {
	        // if statement to check if it is greater than parent
	        if (parent < 0) return cur;
	        else if((arr[parent] == null) || (cur > 0 && arr[cur].compareTo(arr[parent]) >= 0)) {
	            swap(cur, parent);
	            return swim(parent, getParent(parent));
	        }
	        return cur;
	    }
	
	    // returns the max child value of a parent at index i
	    private int getMaxChild(int i) {
	        int kid = (2 * i + 1);
	        // checks if the first child is in the array
	        boolean firstIn = kid < next;
	        // checks if the second child is in the array
	        boolean secondIn = kid + 1 < next;
	        if (firstIn && !secondIn) return kid;
	        else if (firstIn && secondIn) {
	            // if boths kids are in the array it returns the greater of the two
	            // System.out.println(kid);
	            if (arr[kid] == null && arr[kid+1] == null) return i;
	            else if (arr[kid] == null && arr[kid+1] != null) return kid + 1;
	            else if (arr[kid] != null && arr[kid+1] == null) return kid;
	            return (arr[kid].compareTo(arr[kid+1]) > 0) ? kid : kid+1;
	        }
	        return i;
	    }
	
	    public void update(String s, int urgency) {
	        Patient p = table.get(s);
	        if (p == null) {return;}
	        int old = p.urgency();
	        p.setUrgency(urgency);
	        int i = p.posInQueue();
	        if (urgency > old) {swim(i,getParent(i));}
	        if (urgency < old) {sink(i,getMaxChild(i));}
	    }
	
	    // swaps elements at index i and j
	    private void swap(int i, int j) {
	        Patient temp = arr[i];
	        arr[i] = arr[j];
	        arr[j] = temp;
	        // change the pos in queue
	        if (arr[i] != null) arr[i].setPosInQueue(i);
	        if (arr[j] != null) arr[j].setPosInQueue(j);
	    }
	
	    // resizes the array if it is at its max size
	    private void resize() {
	        // doubles the max size of array if it is full
	        if (next == max) max *= 2;
	        // returns if a resize is not necessary
	        else return;
	        // creates new array with the new doubled size
	        Patient[] newArr = new Patient[max];
	        for (int i = 0; i < next; i ++) {
	            newArr[i] = arr[i];
	        }
	        count = count + (next * 2);
	        arr = newArr;
	    }
	
	    public Patient[] getArr() {
	        return arr;
	    }
	
	
	}
