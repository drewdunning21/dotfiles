	        Node<Item> newNode = new Node<Item>(item);
	        if (size == 0) {
	            head = newNode;
	            tail = newNode;
	        } else {
	            tail.next = newNode;
	            tail = newNode;
	        }
	        size ++;
	    }
	
	    public Item dequeue() throws EmptyQueueException {
	        if (isEmpty()) throw new EmptyQueueException();
	        Item retVal = (Item) head.val;
	        head = head.next;
	        size --;
	        return retVal;
	    }
	
	    public boolean isEmpty() {
	        return size == 0;
	    }
	
	    public int size() {
	        return size;
	    }
	
